{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/server-supabase.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/server-supabase.js"
    },
    {
      "src": "/health",
      "dest": "src/server-supabase.js"
    }
  ]
}
